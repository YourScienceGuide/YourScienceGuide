# Clerk — get keys from https://dashboard.clerk.com/~/api-keys
# Or run the dev server once; Clerk Keyless can auto-provision dev keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Mux — get keys from https://dashboard.mux.com/settings/access-tokens
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Used as CORS origin fallback when the request has no Origin header
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email — daily parent digest (Resend: https://resend.com)
# Set both to enable sending; cron still runs but logs skips when unset.
EMAIL_FROM=
RESEND_API_KEY=

# Protect scheduled jobs (Authorization: Bearer <secret>)
CRON_SECRET=

# Supabase — create a project at https://supabase.com/dashboard
# Run supabase/migrations/20260529000000_content_store.sql in the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
